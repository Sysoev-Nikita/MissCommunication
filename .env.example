OPENAI_API_KEY=your_api_key_here
FLASK_SECRET_KEY=replace_me

DEFAULT_LEVEL=A1
DEFAULT_LANGUAGE=german
RECENT_GENERATION_MEMORY_SIZE=12
STUDY_ITEM_REUSE_PROBABILITY=0.7

PHRASE_GENERATION_MODEL=gpt-4o-mini
TRANSLATION_CHECK_MODEL=gpt-4o
FEEDBACK_MODEL=gpt-4o
OPENAI_REASONING_EFFORT=low

OPENAI_API_LOGGING_ENABLED=true
OPENAI_API_LOG_FILE=logs/openai_api.jsonl
